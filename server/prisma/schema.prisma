generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//models

//user info
model User {
  id            String     @id @default(uuid())
  institutionId BigInt     @unique
  name          String
  department    Department
  section       Section?
  role          Role
  password      String
  profilePic    String?    @default("null")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt

  classrooms  Classroom[]
  userclasses UserClass[]

  attendanceSessions AttendanceSession[]
}

//classroom info
model Classroom {
  classId     String     @id @default(uuid())
  subjectName String
  subjectCode String
  department  Department
  section     Section

  teacherId String // FK column
  teacher   User   @relation(fields: [teacherId], references: [id])

  teacherName       String
  teacherProfilePic String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userclasses UserClass[]
}

//student enrolled in class info
model UserClass {
  fieldId String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  classId String
  class   Classroom @relation(fields: [classId], references: [classId])
}

// ----------------Sessions created on every click of teacher------------------ //
model AttendanceSession {
  sessionId  String        @id @default(uuid())
  classId    String
  teacherId  String // FK column
  teacher    User          @relation(fields: [teacherId], references: [id])
  date       DateTime      @default(now())
  status     SessionStatus @default(INACTIVE)
  otp        String
  roomNumber String
  attendance Attendance[]
}

// ----------------For marking attendance of each student class-wise------------ //
model Attendance {
  attendanceId String            @id @default(uuid())
  studentId    String
  sessionId    String
  session      AttendanceSession @relation(fields: [sessionId], references: [sessionId])

  @@unique([studentId, sessionId])
}

enum Role {
  STUDENT
  TEACHER
}

enum SessionStatus {
  ACTIVE
  INACTIVE
}

enum Department {
  ECE
  IT
  CSE
  ME
  EE
}

enum Section {
  A
  B
  C
}
